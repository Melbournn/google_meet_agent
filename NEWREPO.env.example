# ─────────────────────────────────────────────────────────────────────────────
# Google Meet AI Agent — environment configuration
# Copy to `.env` and fill in. NEVER commit the real .env (add it to .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared ───────────────────────────────────────────────────────────────────
# Root folder where the pipeline reads/writes {meetingId}/{meetingId}.json + audio.
# v1 uses a disk drop-box; later swap for a DB + object storage.
RECORDINGS_ROOT=./recordings


# ── Stage 0: CAPTURE — Google Meet (Option A: post-meeting REST API) ──────────
# A Google Cloud project with the Meet API + Drive API enabled.
# For unattended, org-wide capture use a service account with domain-wide delegation.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json
# The Workspace user to impersonate (domain-wide delegation), e.g. an admin/service mailbox.
GOOGLE_IMPERSONATE_SUBJECT=recorder@yourcompany.com
# Optional: restrict polling to a domain / customer id.
GOOGLE_WORKSPACE_CUSTOMER_ID=
# Trigger mode: "poll" or "pubsub".
CAPTURE_TRIGGER=poll
# For pubsub mode: the subscription to pull Workspace Events / recording-created events from.
CAPTURE_PUBSUB_SUBSCRIPTION=
# Prefer Google's own transcript (skip local STT) when available: true/false.
USE_GOOGLE_TRANSCRIPT=true


# ── Stage 1: STT ─────────────────────────────────────────────────────────────
# Only needed if USE_GOOGLE_TRANSCRIPT=false (you transcribe the recording yourself).
# faster-whisper — open-source, self-hosted, free. No Azure.
STT_LANGUAGE=auto                  # BCP-47 tag, or "auto" (detect per file; enables kk routing)
WHISPER_MODEL=large-v3             # base multilingual model (strong ru/en, decent kk)
# Set to route Kazakh-detected audio to a kk specialist (MIT-licensed, free).
# Leave empty first — measure stock large-v3 on your audio before adding this.
WHISPER_KK_MODEL=                  # e.g. abilmansplus/whisper-turbo-ksc2
WHISPER_DEVICE=auto                # auto | cpu | cuda
WHISPER_COMPUTE_TYPE=auto          # auto | int8 | float16 | int8_float16
# Diarization for the MIXED-audio path only (speaker labels on one combined WAV).
# Requires `pip install whisperx` + accepting the pyannote/speaker-diarization
# terms on HuggingFace. Leave empty if recordings are always per-speaker WAVs.
HF_TOKEN=                          # HuggingFace token for pyannote diarization


# ── Stage 2: AGENT (LLM analysis) ────────────────────────────────────────────
# OpenAI (or any OpenAI-compatible endpoint). No Azure.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini           # cheap + good; e.g. gpt-4o, or a compatible provider's model
# Point at a cheaper OpenAI-compatible provider (e.g. DeepSeek); leave empty for OpenAI.
OPENAI_BASE_URL=                   # e.g. https://api.deepseek.com

# Language of the generated summary / action items / analysis.
AGENT_OUTPUT_LANGUAGE=ru


# ── Stage 5: NOTION sync (optional) ──────────────────────────────────────────
NOTION_TOKEN=
NOTION_MEETINGS_DB_ID=
NOTION_TASKS_DB_ID=
